# Video Downloader Configuration

# Download Settings
DOWNLOAD_PATH=~/Downloads/VideoDownloader

# Proxy Settings (optional)
PROXY_URL=http://127.0.0.1:7890
PROXY_DOMAINS=youtube.com,youtu.be,bilibili.com,b23.tv

# Bilibili Settings (optional)
# Option 1: Use cookies file
BILIBILI_COOKIES_FILE=/path/to/cookies.txt
# Option 2: Use browser cookies (chrome, firefox, edge, safari, etc.)
BILIBILI_BROWSER=chrome

# Database
DATABASE_URL=sqlite:///./downloads.db

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
